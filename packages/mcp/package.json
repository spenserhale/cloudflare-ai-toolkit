{
  "name": "@cloudflare-ai-toolkit/mcp",
  "version": "0.0.0",
  "description": "Model Context Protocol (MCP) server for the Cloudflare API.",
  "license": "MIT",
  "author": "Spenser Hale",
  "homepage": "https://github.com/spenserhale/cloudflare-ai-toolkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spenserhale/cloudflare-ai-toolkit.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/spenserhale/cloudflare-ai-toolkit/issues"
  },
  "keywords": [
    "cloudflare",
    "mcp",
    "fastmcp",
    "claude",
    "dns",
    "audit-logs"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "cloudflare-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm --packages external && chmod +x ./dist/index.js",
    "inspect": "npx fastmcp inspect src/index.ts",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare-ai-toolkit/sdk": "workspace:*",
    "@toon-format/toon": "^2.1.0",
    "fastmcp": "^3.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/bun": "latest"
  }
}
