{
  "name": "@cloudflare-ai-toolkit/sdk",
  "version": "0.0.0",
  "description": "Core SDK for the Cloudflare API (types, client, business logic).",
  "license": "MIT",
  "author": "Spenser Hale",
  "homepage": "https://github.com/spenserhale/cloudflare-ai-toolkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spenserhale/cloudflare-ai-toolkit.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/spenserhale/cloudflare-ai-toolkit/issues"
  },
  "keywords": [
    "cloudflare",
    "sdk",
    "api",
    "dns",
    "audit-logs"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "build:js": "bun build ./src/index.ts --outdir ./dist --target node --format esm",
    "build:types": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/bun": "latest"
  }
}
